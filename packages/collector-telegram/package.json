    "@omb/collector-core": "workspace:*",
    "@omb/shared": "workspace:*",
    "grammy": "^1.0.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.3",
    "typescript": "*",
    "vitest": "^3.0.8"
  }
}
