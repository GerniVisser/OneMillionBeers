{
  "name": "@omb/collector-telegram",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "NODE_OPTIONS=--no-network-family-autoselection tsx watch src/index.ts",
    "build": "tsc",
    "start": "node --no-network-family-autoselection dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run"
  },
  "dependencies": {
    "@grammyjs/auto-retry": "^2.0.2",
