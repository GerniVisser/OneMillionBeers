{
  "name": "onemillionbeers",
  "type": "module",
  "private": true,
  "version": "0.0.1",
  "packageManager": "pnpm@10.32.1",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "build:shared": "pnpm --filter @omb/shared build",
    "local": "pnpm run build:shared && concurrently --names \"shared,backend,frontend,collector\" --prefix-colors \"cyan,yellow,magenta,blue\" --kill-others-on-fail \"pnpm --filter @omb/shared dev\" \"dotenv -e .env.local -- pnpm --filter @omb/backend dev\" \"dotenv -e .env.local -- pnpm --filter @omb/frontend dev\" \"dotenv -e .env.local -- pnpm --filter @omb/collector dev\"",
    "infra:up": "docker compose -f docker-compose.local.yml up -d",
    "infra:down": "docker compose -f docker-compose.local.yml down",
    "infra:restart": "docker compose -f docker-compose.local.yml restart",
    "infra:logs": "docker compose -f docker-compose.local.yml logs -f",
    "infra:dev:up": "docker compose -f docker-compose.dev.yml up -d",
    "infra:dev:down": "docker compose -f docker-compose.dev.yml down",
    "infra:dev:restart": "docker compose -f docker-compose.dev.yml restart",
    "infra:dev:build": "docker compose -f docker-compose.dev.yml up -d --build",
    "infra:dev:rebuild": "docker compose -f docker-compose.dev.yml build --no-cache",
    "infra:dev:logs": "docker compose -f docker-compose.dev.yml logs -f",
    "logs:backend": "docker compose -f docker-compose.dev.yml logs -f backend",
    "logs:collector": "docker compose -f docker-compose.dev.yml logs -f collector",
    "logs:frontend": "docker compose -f docker-compose.dev.yml logs -f frontend",
    "logs:gateway": "docker compose -f docker-compose.dev.yml logs -f nginx",
    "db:migrate": "dotenv -e .env.local -- tsx db/migrate.ts",
    "db:seed": "dotenv -e .env.local -- tsx db/seeds/seed.ts",
    "db:reset": "pnpm db:migrate && pnpm db:seed",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "simple-git-hooks"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.0.0",
    "@faker-js/faker": "^10.3.0",
    "@types/pg": "^8.18.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "concurrently": "^9.0.0",
    "dotenv": "^17.3.1",
    "dotenv-cli": "^7.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-svelte": "^2.46.0",
    "lint-staged": "^15.0.0",
    "pg": "^8.20.0",
    "prettier": "^3.0.0",
    "prettier-plugin-svelte": "^3.0.0",
    "simple-git-hooks": "^2.11.0",
    "svelte-eslint-parser": "^0.43.0",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*.{ts,svelte}": [
      "eslint --fix"
    ],
    "*.{ts,js,svelte,json,md,css}": [
      "prettier --write"
    ]
  }
}
