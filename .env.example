# -------------------
# Backend API
# -------------------
DATABASE_URL=postgres://postgres:postgres@postgres:5432/omb
LOG_LEVEL=info

# -------------------
# Collector
# -------------------
COLLECTOR=telegram
BACKEND_URL=http://backend:3000
STORAGE_ENDPOINT=http://minio:9000
# Path-style base URL — bucket and key are appended by the uploader.
# Local (MinIO):  http://localhost:9000          → http://localhost:9000/<bucket>/<key>
# Prod (AWS S3):  https://s3.amazonaws.com       → https://s3.amazonaws.com/<bucket>/<key>
# Do NOT use the virtual-hosted form (https://<bucket>.s3.amazonaws.com) — that would
# embed the bucket name twice in the final URL.
STORAGE_PUBLIC_URL=http://localhost:9000
STORAGE_BUCKET=omb-photos
# Leave empty on EC2 — the AWS SDK will fall back to the IAM instance profile.
# Requires http_put_response_hop_limit = 2 in EC2 metadata options so Docker
# containers can reach the instance metadata service (IMDS).
STORAGE_KEY=minioadmin
STORAGE_SECRET=minioadmin
STORAGE_REGION=auto
LOG_LEVEL=info

# Telegram collector
TELEGRAM_BOT_TOKEN=your-bot-token-here

# -------------------
# Frontend
# -------------------
ORIGIN=https://gernivisser.com  # Required by adapter-node in production
PORT=3001
BACKEND_INTERNAL_URL=http://backend:3000
