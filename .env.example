# -------------------
# Backend API
# -------------------
DATABASE_URL=postgres://postgres:postgres@postgres:5432/omb
LOG_LEVEL=info

# -------------------
# Collector (shared by all collector services)
# -------------------
BACKEND_URL=http://backend:3000
STORAGE_ENDPOINT=http://minio:9000
STORAGE_PUBLIC_URL=http://localhost:9000
STORAGE_BUCKET=omb-photos
STORAGE_KEY=minioadmin
STORAGE_SECRET=minioadmin
STORAGE_REGION=auto
LOG_LEVEL=info

# Telegram collector
TELEGRAM_BOT_TOKEN=your-bot-token-here

# WhatsApp collector (WAHA)
WAHA_API_KEY=your-strong-waha-api-key-here
# PUBLIC_BASE_URL is the site's public domain — used to construct the /whatsapp/status link in alert emails
PUBLIC_BASE_URL=https://onemillionbeers.co.za
# STATUS_TOKEN must be a cryptographically random string of at least 32 characters
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
STATUS_TOKEN=generate-a-random-32-char-hex-string
ENABLE_ALERTS=false
ALERT_EMAIL=you@example.com
SES_FROM_EMAIL=alerts@yourdomain.com
AWS_REGION=us-east-1

# -------------------
# Frontend
# -------------------
ORIGIN=https://onemillionbeers.co.za  # Required by adapter-node in production
PORT=3001
BACKEND_INTERNAL_URL=http://backend:3000
