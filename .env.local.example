# Local development environment variables.
# Copy to .env.local — that file is gitignored and safe to customise.

# -------------------
# Backend API
# -------------------
DATABASE_URL=postgres://postgres:postgres@localhost:5432/omb
LOG_LEVEL=debug

# -------------------
# Collector
# Only needed when running the collector locally (not via `pnpm infra:up:collector`).
# If the collector runs in Docker the values in docker-compose.local.yml take precedence.
# -------------------
BACKEND_URL=http://localhost:3000
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_BUCKET=omb-photos
STORAGE_KEY=minioadmin
STORAGE_SECRET=minioadmin

# -------------------
# Frontend
# ORIGIN is only required for `pnpm preview` (adapter-node production mode).
# PORT is not needed for `pnpm dev` — Vite uses --port 3001 from the package script.
# -------------------
ORIGIN=http://localhost:3001
PORT=3001
