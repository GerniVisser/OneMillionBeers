# Local development environment variables.
# Copy to .env.local — that file is gitignored and safe to customise.

# -------------------
# Backend API
# -------------------
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/omb
LOG_LEVEL=debug

# -------------------
# Collector (shared by all collector services)
# -------------------
BACKEND_URL=http://127.0.0.1:3000
STORAGE_ENDPOINT=http://127.0.0.1:9000
STORAGE_PUBLIC_URL=http://127.0.0.1:9000
STORAGE_BUCKET=omb-photos
STORAGE_KEY=minioadmin
STORAGE_SECRET=minioadmin
STORAGE_REGION=auto

# Telegram collector
TELEGRAM_BOT_TOKEN=your-bot-token-here

# WhatsApp collector (WAHA) — local dev
# collector-whatsapp runs on the host via pnpm dev; WAHA runs in Docker (docker-compose.local.yml)
WAHA_BASE_URL=http://localhost:3100
WAHA_API_KEY=local-api-key
# In local dev there is no nginx — status page is accessed directly at localhost:8080
PUBLIC_BASE_URL=http://localhost:8080
STATUS_TOKEN=dev-token
# ENABLE_ALERTS defaults to false — SES vars are not needed in local dev

# -------------------
# Frontend
# ORIGIN is only required for `pnpm preview` (adapter-node production mode).
# PORT is not needed for `pnpm dev` — Vite uses --port 3001 from the package script.
# -------------------
ORIGIN=http://127.0.0.1:3001
BACKEND_INTERNAL_URL=http://127.0.0.1:3000
